# Public IP of the TURN host
TURN_PUBLIC_IP=203.0.113.10

# Domain/realm used by TURN
TURN_REALM=turn.your-domain.com

# Shared secret used by Coturn REST auth and backend TURN_COTURN_SHARED_SECRET
TURN_SHARED_SECRET=replace_with_long_random_secret

# Relay ports
TURN_MIN_RELAY_PORT=49160
TURN_MAX_RELAY_PORT=49200

# Optional TLS for turns:// (recommended)
# TURN_TLS_CERT=/etc/coturn/certs/fullchain.pem
# TURN_TLS_KEY=/etc/coturn/certs/privkey.pem
