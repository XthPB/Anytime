NODE_ENV=development
PORT=8080
HOST=0.0.0.0
JWT_SECRET=replace_with_at_least_32_characters_random_secret
CORS_ORIGINS=*
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/privately
MAX_INBOX_BATCH=200

# TURN / ICE server settings for production-grade call reliability.
# TURN_PROVIDER can be: disabled | static | twilio
TURN_PROVIDER=disabled

# Static provider mode (optional).
# TURN_STATIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:turn.example.com:3478?transport=udp","turns:turn.example.com:5349?transport=tcp"],"username":"user","credential":"pass"}]
# TURN_URLS=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349?transport=tcp
# TURN_USERNAME=user
# TURN_CREDENTIAL=pass

# Twilio provider mode (recommended for short-lived TURN credentials).
# TURN_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TURN_TTL_SECONDS=600
